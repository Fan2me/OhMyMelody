{
  "name": "ohmymelody-workspace",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --dir app dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "clean": "node scripts/clean.mjs . && turbo run clean"
  },
  "devDependencies": {
    "oxlint": "^1.60.0",
    "playwright-core": "^1.59.1",
    "vite": "^8.0.0",
    "turbo": "^2.5.3",
    "typescript": "^6.0.3"
  }
}
